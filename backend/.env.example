# ─── Anthropic ───────────────────────────────────────────────────────────────
# Required — powers the AI triage summaries
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── GitHub (Coral built-in source) ──────────────────────────────────────────
# Required — the primary data source for issues
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO=owner/repo-name

# ─── Discord (Coral custom source via discord_spec.yaml) ─────────────────────
# Optional — skip if you don't use Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_SERVER_ID=123456789012345678
DISCORD_CHANNEL_ID=123456789012345678

# ─── Slack (Coral built-in source) ───────────────────────────────────────────
# Optional — skip if you don't use Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL_ID=C1234567890

# ─── Gmail (Coral custom source via gmail_spec.yaml) ─────────────────────────
# Optional — skip if you don't use Gmail for OSS notifications
# Generate access token by running the OAuth2 flow described in gmail_spec.yaml
GMAIL_ACCESS_TOKEN=ya29_your_gmail_oauth2_access_token_here
GMAIL_CREDENTIALS_PATH=./gmail_credentials.json

# ─── App config ──────────────────────────────────────────────────────────────
CACHE_TTL=300
PORT=8000
